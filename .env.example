# ============================================================
# SecureWatch SIEM — Environment Configuration
# Copy this file to .env and fill in ALL values before deploy
# ============================================================

# ── Security (REQUIRED — must change before first run) ───────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_hex_string_here

# ── Database ─────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_min16chars

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_min16chars

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── Data Retention ───────────────────────────────────────────
LOG_RETENTION_DAYS=90

# ── Backend Workers ──────────────────────────────────────────
WORKERS=4

# ── Notifications (optional) ─────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=siem@yourdomain.com
SMTP_TO=
SMTP_USE_TLS=true

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#siem-alerts

# ── Threat Intelligence (optional) ───────────────────────────
ABUSEIPDB_API_KEY=
ABUSEIPDB_ENABLED=false
NVD_API_KEY=
NVD_ENABLED=true
